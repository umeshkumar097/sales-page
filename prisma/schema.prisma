generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id          Int      @id @default(autoincrement())
  name        String
  company     String?
  email       String
  phone       String
  projectType String
  message     String?
  createdAt   DateTime @default(now())
}
